# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#     https://docs.fastlane.tools/plugins/available-plugins

# Reduce log verbosity and make CI runs non-interactive.
opt_out_usage

ENV["FASTLANE_SKIP_UPDATE_CHECK"] = "1"
ENV["FASTLANE_HIDE_CHANGELOG"] = "1"
ENV["FASTLANE_DISABLE_COLORS"] = "1"
ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] ||= "120"
ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] ||= "3"
ENV["DELIVER_ITMSTRANSPORTER_ADDITIONAL_UPLOAD_PARAMETERS"] ||= "-t DAV"

before_all do
  setup_ci if ENV["CI"]
end

default_platform(:ios)

platform :ios do
  desc "Sync development certificates and provisioning profiles"
  lane :sync_dev_signing do
    match(
      type: "appstore",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      readonly: true,
      force_for_new_devices: false,
      skip_confirmation: true,
      verbose: false  # Reduce log verbosity to prevent CI hanging
    )
  end

  desc "Sync production certificates and provisioning profiles"
  lane :sync_prod_signing do
    match(
      type: "appstore",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      readonly: true,
      force_for_new_devices: false,
      skip_confirmation: true,
      verbose: false  # Reduce log verbosity to prevent CI hanging
    )
  end

  desc "Archive and upload development to TestFlight"
  lane :deploy_dev do
    # Sync certificates and get provisioning profile info
    sync_dev_signing
    
    # Get signing information
    profile_name = "match AppStore #{ENV['IOS_BUNDLE_ID']}"
    team_id = ENV["APPLE_TEAM_ID"]
    bundle_id = ENV["IOS_BUNDLE_ID"]
    
    puts "🔨 Building IPA with gym..."
    
    # Use gym without specifying SDK - let it use the default from Xcode
    # Flutter already built the app, gym will rebuild with signing
    build_ios_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "maypole.ipa",
      clean: false,  # Don't clean Flutter's build
      include_bitcode: false,
      include_symbols: true,
      suppress_xcode_output: false,  # Keep output flowing to prevent buffering hangs
      disable_xcpretty: false,  # Use xcpretty for better output processing
      buildlog_path: "./fastlane/logs",  # Log to file for debugging
      export_options: {
        method: "app-store",
        teamID: team_id,
        provisioningProfiles: {
          bundle_id => profile_name
        },
        signingStyle: "manual",
        uploadSymbols: true,
        uploadBitcode: false
      },
      xcargs: "-allowProvisioningUpdates"
    )
    
    puts "✅ Build and archive completed successfully!"
    puts "☁️  Uploading to TestFlight..."

    # Step 2: Upload to TestFlight
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/maypole.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
    
    puts "🎉 Deployment completed successfully!"
  end

  desc "Build and upload beta to TestFlight"
  lane :deploy_beta do
    # Sync certificates
    sync_prod_signing

    bundle_id = ENV["IOS_BUNDLE_ID"]

    # Create the App Store Connect API key first so we can look up the latest
    # build number *before* building.
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
      in_house: false
    )

    # Read the marketing version (CFBundleShortVersionString) and build number
    # from pubspec.yaml. Fastfile lives in ios/fastlane, so pubspec is two levels up.
    pubspec = File.read(File.expand_path("../../pubspec.yaml", __dir__))
    version_line = pubspec[/^version:\s*(.+)$/, 1].to_s.strip
    marketing_version = version_line.split("+").first
    pubspec_build = (version_line.split("+")[1] || "0").to_i

    # Find the highest build number already uploaded to TestFlight for this
    # marketing version so we never collide with it (the -19232 duplicate error).
    latest_build = begin
      latest_testflight_build_number(
        api_key: api_key,
        app_identifier: bundle_id,
        version: marketing_version,
        initial_build_number: 0
      )
    rescue => e
      UI.important("Could not fetch latest TestFlight build number (#{e.message}). Falling back to pubspec build number.")
      0
    end

    # Use the highest of (TestFlight latest + 1) and the pubspec build number.
    build_number = [latest_build + 1, pubspec_build].max
    UI.message("📦 Uploading build #{build_number} (TestFlight latest: #{latest_build}, pubspec: #{pubspec_build})")

    max_attempts = 3
    attempt = 0
    begin
      attempt += 1

      # Build the app, overriding the Flutter build number so CFBundleVersion is
      # unique. Command-line build settings take precedence over Generated.xcconfig.
      build_app(
        workspace: "Runner.xcworkspace",
        scheme: "Runner",
        export_method: "app-store",
        xcargs: "FLUTTER_BUILD_NUMBER=#{build_number} CURRENT_PROJECT_VERSION=#{build_number}",
        export_options: {
          method: "app-store",
          provisioningProfiles: {
            bundle_id => "match AppStore #{bundle_id}"
          }
        }
      )

      # Upload to TestFlight (beta group)
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true,
        distribute_external: true,
        groups: ["Beta Testers"],
        notify_external_testers: true,
        changelog: "New beta release with bug fixes and improvements"
      )
    rescue => e
      duplicate_error = e.message =~ /already been used|-19232|must be higher than the previously uploaded/i
      if duplicate_error && attempt < max_attempts
        build_number += 1
        UI.important("⚠️ Build number already used on App Store Connect. Rebuilding with build #{build_number} (attempt #{attempt + 1}/#{max_attempts})...")
        retry
      else
        raise e
      end
    end
  end

  desc "Upload pre-built IPA to TestFlight"
  lane :upload_ipa_only do
    # Create API key for App Store Connect
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
      in_house: false
    )

    # Upload the IPA that was manually created
    # Note: build_app creates maypole.ipa by default
    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/maypole.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end

  desc "Upload pre-built IPA to TestFlight Beta Testing"
  lane :upload_beta_ipa do
    # Create API key for App Store Connect
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
      in_house: false
    )

    # Upload the IPA that was built by Flutter with production config
    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/maypole.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: true,
      groups: ["Beta Testers"],
      notify_external_testers: true,
      changelog: "New beta release with bug fixes and improvements"
    )
  end

  desc "Debug build using xcodebuild directly (alternative to gym)"
  lane :deploy_dev_debug do
    # Sync certificates and get provisioning profile info
    sync_dev_signing
    
    profile_name = "match AppStore #{ENV['IOS_BUNDLE_ID']}"
    team_id = ENV["APPLE_TEAM_ID"]
    bundle_id = ENV["IOS_BUNDLE_ID"]
    
    puts "🔨 Building with xcodebuild directly (debug mode)..."
    
    # Archive using xcodebuild directly with explicit output
    sh(
      "set -o pipefail && xcodebuild",
      "-workspace", "Runner.xcworkspace",
      "-scheme", "Runner", 
      "-configuration", "Release",
      "-destination", "generic/platform=iOS",
      "-archivePath", "../build/ios/Runner.xcarchive",
      "archive",
      "CODE_SIGN_STYLE=Manual",
      "PROVISIONING_PROFILE_SPECIFIER=#{profile_name}",
      "DEVELOPMENT_TEAM=#{team_id}",
      "-allowProvisioningUpdates",
      "| tee ../build/ios/xcodebuild.log | xcpretty --color --simple || cat ../build/ios/xcodebuild.log"
    )
    
    puts "✅ Archive created, now exporting..."
    
    # Export using xcodebuild
    sh(
      "xcodebuild",
      "-exportArchive",
      "-archivePath", "../build/ios/Runner.xcarchive",
      "-exportPath", "../build/ios/ipa",
      "-exportOptionsPlist", "../ExportOptions.plist",
      "-allowProvisioningUpdates"
    )
    
    # Rename IPA to expected name
    sh("mv ../build/ios/ipa/Runner.ipa ../build/ios/ipa/maypole.ipa || true")
    
    puts "✅ IPA exported, now uploading to TestFlight..."
    
    # Upload to TestFlight
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/maypole.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
    
    puts "🎉 Deployment completed successfully!"
  end

  desc "Build and upload production to TestFlight/App Store"
  lane :deploy_prod do
    # Sync certificates
    sync_prod_signing

    # Build the app
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          ENV["IOS_BUNDLE_ID"] => "match AppStore #{ENV['IOS_BUNDLE_ID']}"
        }
      }
    )

    # Create API key for App Store Connect
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
      in_house: false
    )

    # Upload to App Store
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
